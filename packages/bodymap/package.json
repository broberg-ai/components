{
  "name": "@broberg/bodymap",
  "version": "0.2.4",
  "description": "Interactive body pain-map: a body a patient clicks to mark where it hurts, producing a structured PainReport (bodymap/v1). Framework-neutral core (region taxonomy + zod PainReport model + selection) + a 2D SVG React renderer + a rotatable 3D renderer (vanilla three.js) on the SAME core.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "models",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./three": {
      "types": "./dist/three.d.ts",
      "import": "./dist/three.js",
      "require": "./dist/three.cjs"
    },
    "./models/*": "./models/*"
  },
  "scripts": {
    "build": "rm -rf dist && tsup && node verify-exports.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "three": ">=0.160.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/three": "^0.185.0",
    "happy-dom": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.185.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "bodymap",
    "pain-map",
    "smertekort",
    "body-chart",
    "clinical",
    "react",
    "3d",
    "three",
    "webgl",
    "broberg"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/broberg-ai/components.git",
    "directory": "packages/bodymap"
  },
  "publishConfig": {
    "access": "public"
  }
}
