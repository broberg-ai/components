{
  "name": "@broberg/mcp",
  "version": "0.4.0",
  "description": "Genuinely-reusable MCP-server toolkit for the broberg.ai fleet: composable transports (stdio + Streamable-HTTP + SSE), composable auth (static Bearer, hashed 3-tier, OAuth 2.1 PKCE), and one typed defineTool registry (kind write-guard + per-tool scopes + uniform envelope + audit) that drives both the low-level Server and high-level McpServer paths. Owns the plumbing, never your domain tools.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": ["dist", "bin", "README.md"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "broberg-mcp": "./bin/mcp.mjs" },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./oauth": {
      "types": "./dist/oauth.d.ts",
      "import": "./dist/oauth.js",
      "require": "./dist/oauth.cjs"
    },
    "./oauth-web": {
      "types": "./dist/oauth-web.d.ts",
      "import": "./dist/oauth-web.js",
      "require": "./dist/oauth-web.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.12",
    "express": "^5",
    "jose": "^5 || ^6",
    "zod": "^3"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "jose": { "optional": true }
  },
  "dependencies": {
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.0",
    "express": "^5.2.1",
    "jose": "^6.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^3.23.8"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "stdio",
    "sse",
    "streamable-http",
    "oauth",
    "tool-registry",
    "broberg"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/broberg-ai/components",
    "directory": "packages/mcp"
  },
  "publishConfig": { "access": "public" }
}
