{
  "name": "@broberg/theme",
  "version": "0.1.0",
  "description": "Headless design-token theme store + neutral CSS baseline (Tailwind v4) for the broberg.ai estate. Framework-agnostic core + thin React/Preact adapters.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": ["dist", "css", "README.md"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./preact": {
      "types": "./dist/preact.d.ts",
      "import": "./dist/preact.js",
      "require": "./dist/preact.cjs"
    },
    "./css": "./css/neutral-preset.css",
    "./css/neutral-preset.css": "./css/neutral-preset.css"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "preact": ">=10",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "preact": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "jsdom": "^25.0.1",
    "preact": "^10.24.0",
    "react": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": { "access": "public" }
}
