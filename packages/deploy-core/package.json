{
  "name": "@broberg/deploy-core",
  "version": "0.1.0",
  "description": "Fly Live HMAC incremental-sync, Cloudflare Pages, Fly Machines REST client, and deploy-event bus — the shared deploy execution layer for the broberg.ai fleet.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": ["dist", "README.md"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "fly",
    "deploy",
    "hmac",
    "sync",
    "cloudflare",
    "broberg"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/broberg-ai/components",
    "directory": "packages/deploy-core"
  },
  "publishConfig": { "access": "public" }
}
